# ============================================================
# Pakalon Backend — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=["http://localhost:3000","https://pakalon.com"]

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=pakalon
POSTGRES_PASSWORD=pakalon
POSTGRES_DB=pakalon
DATABASE_URL=postgresql+psycopg://pakalon:pakalon@localhost:5432/pakalon

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk ─────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Polar (Billing) ───────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=whsec_...
POLAR_PRODUCT_ID=prod_...

# ── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@pakalon.com

# ── OpenRouter ────────────────────────────────────────────────
OPENROUTER_MASTER_KEY=sk-or-v1-...

# ── Security ──────────────────────────────────────────────────
# 32+ byte random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_generate_random_32_byte_hex

# ── APScheduler ───────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
